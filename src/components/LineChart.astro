---
type Props = {
    counts: number[];
    dates: string[];
};

const { counts, dates } = Astro.props as Props;

const width = 30 * 16;
const height = 30 * 9;

const paddingTop = 16;
const paddingRight = 16;
const paddingBottom = 32;
const paddingLeft = 36;

const chartScale = 1.3;

const actualMax = Math.max(...counts, 1);
const max = actualMax * chartScale;

const innerWidth = width - paddingLeft - paddingRight;
const innerHeight = height - paddingTop - paddingBottom;
const realWidth = innerWidth / chartScale;

const points = counts.map((count, index) => {
    const x =
        counts.length === 1
            ? paddingLeft + innerWidth / 2
            : paddingLeft + (index / (counts.length - 1)) * realWidth;

    const y = paddingTop + (1 - count / max) * innerHeight;

    return { x, y, count, date: dates[index] };
});

const pointstring = points.map((p) => `${p.x},${p.y}`).join(" ");

const axisStartX = paddingLeft;
const axisStartY = paddingTop + innerHeight;

const xAxisEndX = paddingLeft + innerWidth;
const xAxisEndY = axisStartY;

const yAxisEndX = paddingLeft;
const yAxisEndY = paddingTop;

// 寻找最右侧的最大值点.
const maxIndex = counts.reduce(
    (bestIdx, count, idx) => (count >= counts[bestIdx] ? idx : bestIdx),
    0,
);
const maxPoint = points[maxIndex];

function formatDate(iso: string): string {
    const d = new Date(iso);
    return `${d.getMonth() + 1}/${d.getDate()}`;
}
---

<svg
    class="line-chart"
    viewBox={`0 0 ${width} ${height}`}
    role="img"
    aria-label="Blog Posts growth chart"
>
    <defs>
        <marker
            id="line-chart-arrow"
            markerWidth="8"
            markerHeight="8"
            refX="6"
            refY="4"
            orient="auto"
            markerUnits="strokeWidth"
        >
            <path class="line-chart__arrow" d="M0,0 L8,4 L0,8 Z"></path>
        </marker>
    </defs>

    <line
        class="line-chart__axis"
        x1={axisStartX}
        y1={axisStartY}
        x2={xAxisEndX}
        y2={xAxisEndY}
        marker-end="url(#line-chart-arrow)"></line>

    <line
        class="line-chart__axis"
        x1={axisStartX}
        y1={axisStartY}
        x2={yAxisEndX}
        y2={yAxisEndY}
        marker-end="url(#line-chart-arrow)"></line>

    <line
        class="line-chart__guide"
        x1={axisStartX}
        y1={maxPoint.y}
        x2={maxPoint.x}
        y2={maxPoint.y}></line>

    <text
        class="line-chart__label"
        x={axisStartX - 6}
        y={maxPoint.y}
        text-anchor="end"
        dominant-baseline="middle">{actualMax}</text
    >

    {
        dates.length > 0 && (
            <>
                <text
                    class="line-chart__label"
                    x={axisStartX}
                    y={axisStartY + 18}
                    text-anchor="middle"
                >
                    {formatDate(dates[0])}
                </text>
                <text
                    class="line-chart__label"
                    x={points[points.length - 1].x}
                    y={axisStartY + 18}
                    text-anchor="middle"
                >
                    {formatDate(dates[dates.length - 1])}
                </text>
            </>
        )
    }

    <polyline class="line-chart__line" points={pointstring}></polyline>

    {
        points.map((point) => (
            <circle class="line-chart__point" cx={point.x} cy={point.y} r="3">
                <title>{`${point.date}: ${point.count} 篇`}</title>
            </circle>
        ))
    }
</svg>

<style>
    .line-chart {
        width: 100%;
        height: auto;
    }
    .line-chart__line {
        fill: none;
        stroke: currentColor;
        stroke-width: 1;
    }
    .line-chart__point {
        fill: currentColor;
        cursor: pointer;
    }
    .line-chart__axis {
        stroke: currentColor;
        stroke-width: 1.5;
    }
    .line-chart__arrow {
        fill: currentColor;
    }
    .line-chart__guide {
        stroke: currentColor;
        stroke-width: 1;
        stroke-dasharray: 4 4;
        opacity: 0.3;
    }
    .line-chart__label {
        font-size: 10px;
        fill: currentColor;
        opacity: 0.7;
    }
</style>

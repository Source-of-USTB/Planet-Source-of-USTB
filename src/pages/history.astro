---
import BaseLayout from "../layouts/BaseLayout.astro";
import LineChart from "../components/LineChart.astro";
import "../styles/page.css";

import { readFile } from "node:fs/promises";
import { join } from "node:path";
type PostCountSnapshot = {
    date: string;
    total: number;
    counts: Record<string, number>;
};

async function readJson<T>(path: string, fallback: T): Promise<T> {
    try {
        return JSON.parse(await readFile(path, "utf-8")) as T;
    } catch (e) {
        if (e instanceof Error && "code" in e && e.code === "ENOENT") {
            return fallback;
        }
        throw e;
    }
}

const targetPath = "src/data/generated/";

const snapshots = await readJson<PostCountSnapshot[]>(
    join(targetPath, "post-counts.json"),
    [],
);

const postCounts: number[] = snapshots.map((snapshot) => snapshot.total);
---

<BaseLayout>
    <section class="page">
        <h1 class="page-title">History</h1>
        <p class="page-description">
            Statistics on the Number of Historical Articles
        </p>
    </section>

    <LineChart counts={postCounts} dates={snapshots.map((s) => s.date)} />
</BaseLayout>
